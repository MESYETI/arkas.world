<html lang="en">
	<head>
		<%- include("partial/head"); %>
	</head>
	<body>
		<div class="body">
			<%- include("partial/header"); %>
			<table>
				<tr>
					<td style="width: 100%">
						<img src="/data/<%= id %>/screenshot.png" width="100%" height="100%">
					</td>
					<td style="width: 320px" valign=top>
						<h1><%= game.name %></h1>
						<img src="/data/<%= id %>/thumb.png"><br>
						<hr>
						<p><%= game.description %></p>
					</td>
				</tr>
				<tr>
					<td>
						<hr>
						<% for (let i = 0; i < game.fullDesc.length; ++ i) { %>
							<p><%= game.fullDesc[i] %></p>
						<% } %>

						<hr>
						<h2>Download</h2>

						<% if (game.download) { %>
							<button>Download</button>
						<% } else { %>
							<p>Download currently unavailable</p>
						<% } %>
					</td>
				</tr>
			</table>
		</body>
	</body>
</html>
